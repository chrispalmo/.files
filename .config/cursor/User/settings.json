{
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.integrated.profiles.osx": {
    "bash": null,
    "zsh": {
      "path": "zsh",
      "args": ["-l"]
    },
    "fish": null,
    "tmux": null,
    "pwsh": null
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {
    "source.formatDocument": "explicit",
    "source.fixAll": "explicit"
  },
  "files.autoSave": "off",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "search.collapseResults": "auto",
  "workbench.sideBar.location": "right",
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.tabSize": 4,
  "editor.cursorStyle": "line",
  "editor.insertSpaces": false,
  "editor.lineNumbers": "on",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "editor.wordWrap": "off",
  "editor.autoClosingBrackets": "never",
  "editor.autoClosingQuotes": "never",
  "editor.autoSurround": "never",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "security.workspace.trust.untrustedFiles": "open",
  "editor.suggestSelection": "first",
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.formatOnSave": true,
  "gitlens.advanced.messages": {
    "suppressGitMissingWarning": true
  },
  "editor.accessibilitySupport": "off",
  "workbench.startupEditor": "none",
  "cucumberautocomplete.onTypeFormat": true,
  "editor.inlineSuggest.enabled": true,
  "backgroundCover.imagePath": "${userHome}/Dropbox/theme/fern-leaves-dark.jpeg",
  "backgroundCover.opacity": 0.2,
  "svelte.enable-ts-plugin": true,
  "eslint.runtime": "${userHome}/.n/bin/node",
  "vim.leader": "<space>",
  "accessibility.signals.terminalBell": {
    "sound": "off"
  },
  "terminal.integrated.enableVisualBell": false,
  "workbench.preferredHighContrastColorTheme": "Ayu Dark Bordered",
  "git.autofetch": true,
  "cursor.terminal.usePreviewBox": true,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.general.globalCursorIgnoreList": [
    "# **/.env",
    "# **/.env.*",
    "**/credentials.json",
    "**/credentials.*.json",
    "**/secret.json",
    "**/secrets.json",
    "**/*.key",
    "**/*.pem",
    "**/*.pfx",
    "**/*.p12",
    "**/*.crt",
    "**/*.cer",
    "**/id_rsa",
    "**/id_dsa",
    "**/.ssh/id_*"
  ],
  "window.autoDetectColorScheme": false
}
